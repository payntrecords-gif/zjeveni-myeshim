rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kdokoliv může vytvořit vlastní žádost
    match /pendingUsers/{email} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Schválení uživatelé - čitelné pro všechny (pro localStorage auth check)
    match /approvedUsers/{email} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // User data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
