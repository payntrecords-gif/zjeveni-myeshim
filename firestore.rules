rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isApproved() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/approvedUsers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/approvedUsers/$(request.auth.uid)).data.status == 'approved';
    }

    match /pendingUsers/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /approvedUsers/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create, update, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId && isApproved());
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId &&
        isApproved();
      allow delete: if isAdmin();
    }
  }
}
